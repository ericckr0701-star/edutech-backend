FLASK_SECRET_KEY=please-set-a-long-random-string
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
# 云部署时常见：整串 mysql://user:pass@host:port/db（设置了则优先于下面分项）
# DATABASE_URL=
# MYSQL_PORT=3306
# 作业最小 users 表：新建空库 group_project，不要导入 EduTech（或设 USE_EDUTECH_USERS=false）
# 小组全库：education_cli + 已导入 EduTech_Final_DB.sql（默认识别为 EduTech 模式）
MYSQL_DATABASE=education_cli
# 可选：强制 true/false；留空则仅当 MYSQL_DATABASE=education_cli 时用 EduTech 表结构
USE_EDUTECH_USERS=
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
